# ─────────────────────────────────────────────────────────────
# InspireMe environment template
# Copy to `.env` and fill in. Never commit `.env`.
# ─────────────────────────────────────────────────────────────

# Gemini (Google AI Studio) — used by scripts and (optionally) the app
EXPO_PUBLIC_GEMINI_API_KEY=
EXPO_PUBLIC_GEMINI_MODEL=gemini-2.5-flash

# Supabase — public values are safe to ship with the app (RLS protects data)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — service role (SCRIPTS ONLY; never expose to the app)
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=

# Optional fallback image providers (Wikimedia is tried first)
EXPO_PUBLIC_PEXELS_API_KEY=
EXPO_PUBLIC_PIXABAY_API_KEY=

# Google AdMob (per-platform interstitial ids)
EXPO_PUBLIC_ADMOB_ANDROID_INTERSTITIAL_ID=
EXPO_PUBLIC_ADMOB_IOS_INTERSTITIAL_ID=
