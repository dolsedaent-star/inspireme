# ─────────────────────────────────────────────────────────────
# InspireMe mobile app — environment variables
# Copy this file to .env and fill in your values.
# Expo CLI reads .env from this directory (apps/mobile/).
# ─────────────────────────────────────────────────────────────

# Supabase — Supabase 대시보드 > Project Settings > API 에서 확인
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Gemini (선택) — 앱 내 Gemini 호출 시 필요
EXPO_PUBLIC_GEMINI_API_KEY=
EXPO_PUBLIC_GEMINI_MODEL=gemini-2.5-flash

# AdMob — 실제 광고 단위 ID (없으면 Google 테스트 ID가 자동 사용됨)
# Android: AdMob 대시보드 > 앱 > 광고 단위 > 전면 광고
EXPO_PUBLIC_ADMOB_ANDROID_INTERSTITIAL_ID=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX
# iOS: AdMob 대시보드 > 앱 > 광고 단위 > 전면 광고
EXPO_PUBLIC_ADMOB_IOS_INTERSTITIAL_ID=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX
