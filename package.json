{
  "name": "inspireme",
  "version": "0.1.0",
  "private": true,
  "description": "한 사람의 인생을 디지털 매거진처럼 보여주는 인터랙티브 전기 앱.",
  "workspaces": [
    "apps/*",
    "packages/*",
    "scripts"
  ],
  "scripts": {
    "make-env": "powershell -ExecutionPolicy Bypass -File make-env.ps1",
    "mobile": "npm --workspace apps/mobile run start",
    "android": "npm --workspace apps/mobile run android",
    "ios": "npm --workspace apps/mobile run ios",
    "generate": "npm --workspace scripts run generate",
    "sync-candidates": "npm --workspace scripts run sync-candidates",
    "lint": "echo \"(lint to be configured)\""
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "expo": "~54.0.34",
    "react": "19.1.0",
    "react-native": "0.81.5"
  }
}
